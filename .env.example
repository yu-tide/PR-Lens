# GitHub Personal Access Token used by the server-side GitHub fetch pipeline.
# Do not expose this token to the browser.
# Copy this value to .env.local for local development.
GITHUB_TOKEN=your_github_token_here
AI_API_KEY=your_ai_api_key_here
AI_BASE_URL=https://api.example.com
AI_MODEL_NAME=model-name
NEXT_PUBLIC_APP_NAME=PR Lens

# Bailian / DashScope OpenAI-compatible Chat Completions API.
# Server-side only. Do not expose to the browser.
BAILIAN_API_KEY=

# Default China mainland endpoint for OpenAI-compatible mode.
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Example model name. Adjust based on your Bailian console.
BAILIAN_MODEL=qwen-plus
